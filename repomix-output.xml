                          <SelectItem value="glueops">GlueOps</SelectItem>
                        </SelectContent>
                      </Select>
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />

              <FormField
                control={updateForm.control}
                name="public_ip_address"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>Public IP / Hostname</FormLabel>
                    <FormControl>
