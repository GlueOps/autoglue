	u1 := uuid.New()
	u2 := uuid.New()

	got, err := parseUUIDs([]string{u1.String(), u2.String()})
	if err != nil {
		t.Fatalf("parseUUIDs returned error: %v", err)
	}
	if len(got) != 2 {
